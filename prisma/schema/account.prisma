model Account {
  id                String  @id
  type              String
  provider          String
  scope             String?
  accessToken       String?
  expiresAt         Int?
  idToken           String?
  providerAccountId String
  refreshToken      String?
  sessionState      String?
  tokenType         String?
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}
